# LLM Configurations
# Priority 1: Google Gemini LLM API key
GEMINI_API_KEY=your_gemini_api_key_here

# Priority 2: Grok API key (fallback if Gemini key is omitted)
GROK_API_KEY=your_grok_api_key_here

# Priority 3: OpenAI API key (fallback if others are omitted)
OPENAI_API_KEY=your_openai_api_key_here


# Reddit API Setup
# Go to https://www.reddit.com/prefs/apps and create a script application.
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=WoWLeadAgent/1.0 (by /u/YourRedditUsername)

# Discord Bot Setup
# Requires a bot token and the bot joined to the target server.
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# SMTP Server Configurations (Email)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_smtp_email@gmail.com
SMTP_PASSWORD=your_app_specific_password_here
